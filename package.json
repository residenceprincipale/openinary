{
  "name": "openinary-monorepo",
  "version": "1.0.0",
  "description": "Openinary Media API Monorepo",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "dev:api": "pnpm --filter api dev",
    "dev:web": "pnpm --filter web dev",
    "build": "turbo run build",
    "build:api": "pnpm --filter api build",
    "build:web": "pnpm --filter web build",
    "start": "turbo run start",
    "start:api": "pnpm --filter api start",
    "start:web": "pnpm --filter web start",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "type-check": "turbo run type-check",
    "clean": "pnpm --filter api clean && pnpm --filter web clean",
    "docker:build": "docker-compose build",
    "docker:up": "docker-compose up",
    "docker:down": "docker-compose down",
    "docker:push": "docker buildx build --platform linux/amd64 -t residenceprincipale/openinary:latest -f docker/full.Dockerfile . && docker push residenceprincipale/openinary:latest",
    "init-env": "node scripts/init-env.js",
    "secure-db": "node scripts/secure-db.js"
  },
  "devDependencies": {
    "@better-auth/cli": "^1.4.21",
    "better-sqlite3": "^11.10.0",
    "turbo": "^2.8.12"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=8.0.0"
  },
  "packageManager": "pnpm@9.0.0",
  "type": "module"
}
